{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true
  },
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "tools/**/*.ts",
    "scripts/**/*.ts"
  ]
}
